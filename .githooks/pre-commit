#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

# Format check
UNFORMATTED=$(gofmt -l . 2>&1)
if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: unformatted files:"
    echo "$UNFORMATTED"
    echo ""
    echo "Run: gofmt -w ."
    exit 1
fi

# Format markdown files with prettier
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM -- '*.md')
if [ -n "$STAGED_MD" ]; then
    echo "Formatting markdown files with prettier..."
    npx --yes prettier --write $STAGED_MD
    git add $STAGED_MD
fi

# Vet
echo "Running go vet..."
go vet ./...

# Tests
echo "Running tests..."
go test -race -count=1 ./...

echo "All checks passed."
